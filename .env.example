# App
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:5173
# Optional external URL used in password reset emails.
API_BASE_URL=http://localhost:3001
SESSION_SECRET=change-this-session-secret
SESSION_NAME=expiryalert.sid

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Directus
DIRECTUS_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-this-password

# Push notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Team password reset email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Team password reset token TTL (minutes)
TEAM_PASSWORD_RESET_TTL_MINUTES=30
